# Claude Code settings (contains local hooks, permissions, session data)
.claude/

# Dataset - do not commit the raw Kaggle data (users download it themselves).
# Processed CSVs are regenerated by the pipeline, so they stay ignored too.
data/raw/*.csv
data/processed/*.csv

# Tableau export IS committed — it's the scored deliverable that powers the
# dashboard, so the dashboard can be rebuilt without re-running the pipeline.
data/tableau/*.csv
!data/tableau/churn_dashboard_data.csv

# Trained models
models/*.pkl

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Reports output — figures and metrics ARE committed so the README renders on
# GitHub and recruiters see results without running the pipeline.
# (Intentionally tracked: reports/figures/*.png and reports/model_metrics.json)

# Secrets and credentials - never commit these
.env
.env.*
*.env
secrets.json
credentials.json
config.local.*
*_secret*
*_credentials*
api_keys*
