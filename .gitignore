# Claude Code settings (contains local hooks, permissions, session data)
.claude/

# Dataset - do not commit raw data
data/raw/*.csv
data/processed/*.csv
data/tableau/*.csv

# Trained models
models/*.pkl

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Reports output (regenerated by notebooks)
reports/figures/*.png
reports/model_metrics.json

# Secrets and credentials - never commit these
.env
.env.*
*.env
secrets.json
credentials.json
config.local.*
*_secret*
*_credentials*
api_keys*
